{
  "name": "@guidekit/core",
  "version": "0.1.0",
  "description": "Core engine for GuideKit SDK — DOM intelligence, LLM orchestration, context management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config ../../vitest.config.ts",
    "test:unit": "vitest run --config ../../vitest.config.ts",
    "test:watch": "vitest --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@guidekit/vad": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@guidekit/vad": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "Riazul Islam",
  "keywords": [
    "guidekit",
    "sdk",
    "ai",
    "llm",
    "dom",
    "orchestration",
    "voice",
    "assistant"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/riaz37/guidekit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/riaz37/guidekit#readme",
  "bugs": {
    "url": "https://github.com/riaz37/guidekit/issues"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "marked": "^17.0.4"
  }
}
