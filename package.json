{
  "name": "guidekit",
  "private": true,
  "description": "AI-powered user guidance SDK — DOM intelligence, LLM orchestration, voice, and visual guidance for web apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/riaz37/guidekit.git"
  },
  "homepage": "https://github.com/riaz37/guidekit#readme",
  "keywords": [
    "ai",
    "sdk",
    "guidance",
    "assistant",
    "llm",
    "voice",
    "dom",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint packages/*/src/",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "release": "pnpm changeset version && pnpm install && pnpm build && pnpm changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.1.0",
    "size-limit": "^12.0.0",
    "tsup": "^8.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "version": "0.1.0-beta.3"
}
